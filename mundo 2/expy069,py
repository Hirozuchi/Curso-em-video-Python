p18 = 0
f20 = 0
h = 0
while True:
    i = int(input('Idade: '))
    s = ' '
    while s not in 'MF':
        s = input('Sexo [M/F]: ').upper()
    if i >= 18:
        p18 += 1
    if s == 'M':
        h += 1
    if s == 'F' and i < 20:
        f20 += 1
    c = ' '
    while c not in 'SN':
        c = input('Continuar [S/N]? ').upper()
    if c == 'N':
        break
print(f'Pessoas com Mais de 18: {p18} \nHomens: {h} \nMulheres com menos de 20: {f20}')