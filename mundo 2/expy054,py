from datetime import datetime
year = datetime.now().year
ofage = 0
minor = 0
for i in range(0,7):
    birthyear = int(input('Ano Nascimento:'))
    if year - birthyear >= 21:
        ofage += 1
    elif year - birthyear < 21:
        minor += 1
print(f'Maior de Idade:{ofage} \nMenor de Idade:{minor}')